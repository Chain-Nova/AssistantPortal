<view class="page">
  <!-- 顶栏：与 ChatPage 一致 -->
  <view class="custom-header" style="padding-top: {{statusBarHeight}}px;">
    <view class="header-row">
      <view class="header-title-wrap">
        <text class="header-title">Novi</text>
      </view>
    </view>
  </view>

  <scroll-view
    class="message-list"
    scroll-y
    scroll-into-view="{{scrollTarget}}"
    scroll-with-animation
  >
    <block wx:if="{{messages.length === 0}}">
      <view class="welcome-screen">
        <view class="welcome-hero">
          <lottie
            wx:if="{{showWelcome}}"
            path="/assets/hi.json"
            width="{{180}}"
            height="{{180}}"
            autoplay
            loop
          />
          <text class="welcome-title">{{welcomeTitle}}</text>
          <text class="welcome-subtitle">{{welcomeSubtitle}}</text>
        </view>

        <view class="recommend-section">
          <text class="recommend-label">试试这样问</text>
          <view class="recommend-cards">
            <view
              wx:for="{{recommendedQuestions}}"
              wx:key="id"
              class="recommend-card"
              hover-class="recommend-card-hover"
              bindtap="onRecommendTap"
              data-text="{{item.text}}"
            >
              <text class="recommend-card-text">{{item.text}}</text>
            </view>
          </view>
        </view>
      </view>
    </block>

    <block wx:else>
      <view
        wx:for="{{messages}}"
        wx:key="id"
        id="msg-{{item.id}}"
        class="message-row {{item.role === 'user' ? 'row-right' : 'row-left'}}"
      >
        <view wx:if="{{item.role === 'user'}}" class="bubble user-bubble">
          {{item.content}}
        </view>

        <view wx:else class="bubble assistant-bubble">
          <view class="bubble-content">
            <text wx:if="{{item.content}}">{{item.content}}</text>
            <text wx:elif="{{item.streaming}}">思考中...</text>
            <view wx:if="{{item.streaming}}" class="typing-cursor"></view>
          </view>
          <view
            wx:if="{{!item.streaming && item.content}}"
            class="bubble-actions"
          >
            <view
              class="copy-btn"
              bindtap="copyMessage"
              data-content="{{item.content}}"
            >
              <text class="copy-text">复制</text>
            </view>
          </view>
        </view>
      </view>

      <view class="list-footer-spacer"></view>
    </block>
  </scroll-view>

  <!-- 底栏：相机 | 输入 | 加号（与 Web 文字模式一致，无独立发送键，用键盘发送） -->
  <view class="bottom-bar" style="padding-bottom: calc(16rpx + env(safe-area-inset-bottom));">
    <view class="input-shell">
      <view class="icon-tool" bindtap="noopCamera" aria-label="相机">
        <text class="tool-icon">📷</text>
      </view>
      <input
        class="text-input"
        value="{{input}}"
        bindinput="onInputChange"
        bindconfirm="sendText"
        placeholder="发消息…"
        placeholder-style="color: #999;"
        confirm-type="send"
        disabled="{{sending}}"
        hold-keyboard
      />
      <view class="icon-tool" bindtap="noopMore" aria-label="更多">
        <text class="tool-icon">+</text>
      </view>
      <view class="icon-tool icon-tool-phone" bindtap="openVoice" aria-label="实时语音">
        <text class="tool-icon tool-icon-phone">📞</text>
      </view>
    </view>
  </view>
</view>
