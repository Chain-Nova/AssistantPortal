<view class="page">
  <!-- 顶栏：与 ChatPage 一致 -->
  <view
    class="custom-header {{showWelcome ? 'custom-header--welcome' : ''}}"
    style="padding-top: {{statusBarHeight}}px;"
    bindtap="onTapBlankHideKeyboard"
  >
    <!-- 欢迎页：标题相对整屏宽度居中，不受右侧胶囊留白区域挤压 -->
    <view wx:if="{{showWelcome}}" class="header-title-fullbleed">
      <text class="header-title">Novi</text>
    </view>
    <!-- 会话中：按钮层与标题层分离，标题始终按整栏居中 -->
    <view
      wx:else
      class="header-row"
      style="padding-right: {{headerPaddingRightPx}}px;"
    >
      <view
        class="new-chat-icon-btn"
        catchtap="startNewChat"
        hover-class="new-chat-icon-btn-hover"
        aria-role="button"
        aria-label="新对话"
      >
        <image class="new-chat-icon" src="/assets/icon-new-chat.svg" mode="aspectFit" />
      </view>
      <view class="header-right-balance" aria-hidden="true"></view>
    </view>
    <view wx:if="{{!showWelcome}}" class="header-title-fullbleed header-title-fullbleed--overlay" aria-hidden="true">
      <text class="header-title">Novi</text>
    </view>
  </view>

  <scroll-view
    class="message-list"
    style="padding-bottom: {{listPaddingBottomPx}}px;"
    scroll-y
    scroll-into-view="{{scrollTarget}}"
    scroll-with-animation
    bindtap="onTapBlankHideKeyboard"
  >
    <block wx:if="{{messages.length === 0}}">
      <view class="welcome-screen">
        <view class="welcome-hero">
          <lottie
            wx:if="{{showWelcome}}"
            path="/assets/hi.json"
            width="{{180}}"
            height="{{180}}"
            autoplay
            loop
          />
          <text class="welcome-title">{{welcomeTitle}}</text>
          <text class="welcome-subtitle">{{welcomeSubtitle}}</text>
        </view>

        <view class="recommend-section">
          <text class="recommend-label">试试这样问</text>
          <view class="recommend-cards">
            <view
              wx:for="{{recommendedQuestions}}"
              wx:key="id"
              class="recommend-card"
              hover-class="recommend-card-hover"
              hover-start-time="20"
              hover-stay-time="220"
              catchtap="onRecommendTap"
              data-text="{{item.text}}"
            >
              <text class="recommend-card-text">{{item.text}}</text>
            </view>
          </view>
        </view>
      </view>
    </block>

    <block wx:else>
      <view
        wx:for="{{messages}}"
        wx:key="id"
        id="msg-{{item.id}}"
        class="message-row {{item.role === 'user' ? 'row-right' : 'row-left'}}"
      >
        <view wx:if="{{item.role === 'user'}}" class="bubble user-bubble">
          {{item.content}}
        </view>

        <view wx:else class="bubble assistant-bubble">
          <view class="bubble-content">
            <text wx:if="{{item.content}}">{{item.content}}</text>
            <text wx:elif="{{item.streaming}}">思考中...</text>
            <view wx:if="{{item.streaming}}" class="typing-cursor"></view>
          </view>
        </view>
      </view>

      <view class="list-footer-spacer"></view>
    </block>
  </scroll-view>

  <!-- 底栏：输入 + 实时语音入口（键盘发送）；fixed + 键盘高度避免被遮挡 -->
  <view
    class="bottom-bar"
    style="bottom: {{keyboardHeightPx}}px; padding-bottom: calc(16rpx + env(safe-area-inset-bottom));"
  >
    <view class="input-shell">
      <input
        class="text-input"
        value="{{input}}"
        bindinput="onInputChange"
        bindconfirm="sendText"
        placeholder="发消息…"
        placeholder-style="color: #999;"
        confirm-type="send"
        disabled="{{sending}}"
        adjust-position="{{false}}"
        cursor-spacing="32"
        hold-keyboard
      />
      <view
        class="voice-entry"
        bindtap="openVoice"
        hover-class="voice-entry-hover"
        aria-label="实时语音"
      >
        <image
          class="voice-entry-icon"
          src="/assets/icon-phone-call.svg"
          mode="aspectFit"
        />
      </view>
    </view>
  </view>
</view>
