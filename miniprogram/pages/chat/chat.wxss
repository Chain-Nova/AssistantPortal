/* 聊天页面样式 - 移植自 ChatPage.tsx */

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f7fa;
  overflow: hidden;
  box-sizing: border-box;
}

/* 自定义顶栏 */
.custom-header {
  flex-shrink: 0;
  background-color: #f5f7fa;
  padding-left: 24rpx;
  padding-bottom: 24rpx;
  position: relative;
}

/** 欢迎页去掉左右 padding，让标题在整栏宽度内居中（与胶囊区解耦） */
.custom-header--welcome {
  padding-left: 0;
  padding-right: 0;
}

/** 欢迎页标题条：占满屏宽，flex 水平垂直居中 */
.header-title-fullbleed {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 72rpx;
  box-sizing: border-box;
}

.header-title-fullbleed--overlay {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 24rpx;
  pointer-events: none;
  z-index: 1;
}

.header-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  /* 与标题行高对齐，避免侧栏控件显得比字帽还高 */
  min-height: 68rpx;
  position: relative;
  z-index: 2;
}

.new-chat-icon-btn {
  width: 56rpx;
  height: 56rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  margin-right: 8rpx;
  /* 略下移，与标题文字光学中心对齐（text 组件基线略偏下） */
  transform: translateY(3rpx);
}

.new-chat-icon-btn-hover {
  background-color: rgba(0, 0, 0, 0.05);
}

.new-chat-icon {
  width: 36rpx;
  height: 36rpx;
  display: block;
}

.header-title-wrap {
  flex: 1;
  min-width: 0;
  display: flex;
  justify-content: center;
  align-items: center;
}

/** 与左侧图标等宽，标题视觉居中 */
.header-right-balance {
  width: 56rpx;
  height: 56rpx;
  flex-shrink: 0;
  margin-left: 8rpx;
}

.header-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #111;
  line-height: 1.25;
}

/* 消息列表；底 padding 由内联控制，避让 fixed 底栏与键盘 */
.message-list {
  flex: 1;
  min-height: 0;
  padding-top: 24rpx;
  padding-left: 28rpx;
  padding-right: 28rpx;
  box-sizing: border-box;
}

/* 空会话：欢迎区 + 推荐问题卡片 */
.welcome-screen {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  padding-bottom: 48rpx;
  box-sizing: border-box;
}

.welcome-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 8rpx;
  padding-bottom: 32rpx;
}

.welcome-title {
  margin-top: 8rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #111;
  letter-spacing: 0.02em;
}

.welcome-subtitle {
  margin-top: 16rpx;
  padding-left: 8rpx;
  padding-right: 8rpx;
  font-size: 26rpx;
  line-height: 1.55;
  color: rgba(17, 17, 17, 0.55);
  text-align: center;
  max-width: 620rpx;
}

.recommend-section {
  width: 100%;
  margin-top: 16rpx;
}

.recommend-label {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(17, 17, 17, 0.45);
  margin-bottom: 20rpx;
  padding-left: 4rpx;
}

.recommend-cards {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.recommend-card {
  background-color: #fff;
  border-radius: 20rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  padding: 24rpx 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
  transition: transform 120ms ease-out, background-color 120ms ease-out, box-shadow 120ms ease-out,
    border-color 120ms ease-out;
}

.recommend-card-hover {
  transform: scale(0.985);
  background-color: #f7f9fb;
  border-color: rgba(0, 0, 0, 0.12);
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.08);
}

.recommend-card-hover .recommend-card-text {
  color: #222;
  font-weight: 600;
}

.recommend-card-text {
  font-size: 28rpx;
  line-height: 1.5;
  color: #222;
  transition: color 140ms ease, font-weight 140ms ease;
}

.list-footer-spacer {
  height: 24rpx;
}

.message-row {
  display: flex;
  margin-bottom: 24rpx;
}

.row-right {
  justify-content: flex-end;
}

.row-left {
  justify-content: flex-start;
}

.user-bubble {
  max-width: 85%;
  border-radius: 28rpx;
  border-bottom-right-radius: 10rpx;
  padding: 18rpx 24rpx;
  font-size: 30rpx;
  line-height: 1.6;
  color: #fff;
  background-color: #333;
  word-break: break-all;
}

.assistant-bubble {
  max-width: 88%;
  border-radius: 28rpx;
  border-bottom-left-radius: 10rpx;
  background-color: #f0f2f5;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  line-height: 1.6;
  color: #222;
}

.bubble-content {
  white-space: pre-wrap;
  word-break: break-all;
  overflow-wrap: anywhere;
}

.typing-cursor {
  display: inline-block;
  width: 6rpx;
  height: 28rpx;
  margin-left: 8rpx;
  background-color: rgba(0, 0, 0, 0.45);
  border-radius: 4rpx;
  vertical-align: middle;
  animation: pulse 1.5s cubic-bezier(0.4, 0, 0.6, 1) infinite;
}

/* 底栏：fixed 抬高，配合键盘高度避免遮挡 */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 200;
  background-color: #f5f7fa;
  padding-left: 24rpx;
  padding-right: 24rpx;
  padding-top: 16rpx;
}

.input-shell {
  display: flex;
  align-items: center;
  gap: 12rpx;
  border-radius: 44rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.08);
  background-color: #fff;
  padding: 12rpx 14rpx 12rpx 24rpx;
}

.voice-entry {
  flex-shrink: 0;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: linear-gradient(145deg, #2c2c2c 0%, #161616 100%);
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.12);
}

.voice-entry-hover {
  opacity: 0.92;
}

.voice-entry-icon {
  width: 42rpx;
  height: 42rpx;
}

.text-input {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 30rpx;
  color: #333;
  padding: 0 12rpx 0 4rpx;
}

@keyframes pulse {
  0%,
  100% {
    opacity: 1;
  }
  50% {
    opacity: 0;
  }
}
